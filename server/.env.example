# ============================================================
# LifeSim backend — environment
# Copy to `.env` and fill in. NEVER commit the real .env.
# (Railway: set these in the service "Variables" tab instead.)
# ============================================================

# ---- Community (shared world) ----
PORT=3001
# Set by the Railway PostgreSQL plugin; leave empty for in-memory dev.
DATABASE_URL=

# ============================================================
# P2E — real Solana payouts
# ============================================================
# Master switch. Stays OFF until you flip it, so nothing pays out by
# accident. Turn on ONLY after funding the treasury + your own legal
# and security review.
P2E_PAYOUTS_ENABLED=false

# Network: devnet (free, safe — DEVELOP HERE) | testnet | mainnet-beta
P2E_SOLANA_NETWORK=devnet
# Optional custom RPC (recommended for mainnet — use a paid RPC, not the
# public endpoint). Leave empty to use the default cluster endpoint.
P2E_SOLANA_RPC_URL=

# Asset paid out: SOL (native, simplest) or USDC (SPL token).
P2E_REWARD_ASSET=SOL
# USDC mint (only used when P2E_REWARD_ASSET=USDC). Defaults to the
# canonical mainnet/devnet USDC mint if omitted.
P2E_REWARD_MINT=

# ---- TREASURY (SECRET — server only, NEVER in client or git) ----
# The wallet that funds payouts. Accepts a base58 secret key (Phantom
# "Export Private Key") OR a JSON byte array (solana-keygen). Fund this
# wallet; players are paid FROM it.
P2E_TREASURY_SECRET=

# ---- Economy tuning (all optional; sane defaults in economy.js) ----
# How many reward credits (RC) equal 1 whole SOL/USDC. 100000 → 1 RC ≈ 0.00001 SOL.
P2E_CREDITS_PER_UNIT=100000
P2E_MIN_WITHDRAW=2000          # min RC to cash out
P2E_DAILY_WITHDRAW_CAP=20000   # max RC withdrawable per 24h
P2E_WITHDRAW_COOLDOWN_MS=60000 # min gap between withdrawals
P2E_WITHDRAW_FEE=0             # RC kept by treasury per cashout
P2E_DAILY_REWARD=50            # login bonus RC / 24h
P2E_DAILY_EARN_CAP=1500        # max RC mintable per 24h (all sources)
